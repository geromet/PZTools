<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:UI.Assets"
             x:Class="UI.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />

        <Styles>
            <Styles.Resources>

                <!-- ══ COLOR PALETTE ══ -->

                <!-- Backgrounds (dark → light) -->
                <SolidColorBrush x:Key="BgBase" Color="#111114" />
                <SolidColorBrush x:Key="BgPanel" Color="#18181C" />
                <SolidColorBrush x:Key="BgSurface" Color="#1E1E24" />
                <SolidColorBrush x:Key="BgElevated" Color="#26262E" />
                <SolidColorBrush x:Key="BgInput" Color="#2C2C36" />
                <SolidColorBrush x:Key="BgHover" Color="#32323E" />
                <SolidColorBrush x:Key="BgHoverDark" Color="#2E2E2F" />

                <!-- Borders -->
                <SolidColorBrush x:Key="BorderSubtle" Color="#2E2E3A" />
                <SolidColorBrush x:Key="BorderMid" Color="#3C3C4C" />

                <!-- Accent -->
                <SolidColorBrush x:Key="Accent" Color="#4A7FA8" />
                <SolidColorBrush x:Key="AccentHover" Color="#5A93BF" />
                <SolidColorBrush x:Key="AccentMuted" Color="#2A4F6A" />
                <SolidColorBrush x:Key="AccentMutedDark" Color="#233D33" />

                <!-- Text -->
                <SolidColorBrush x:Key="TextPrimary" Color="#E4E4EA" />
                <SolidColorBrush x:Key="TextSecondary" Color="#8A8A98" />
                <SolidColorBrush x:Key="TextMuted" Color="#5A5A6A" />

                <!-- Status -->
                <SolidColorBrush x:Key="StatusError" Color="#C84B4B" />
                <SolidColorBrush x:Key="StatusWarning" Color="#C88B2A" />
                <SolidColorBrush x:Key="StatusSuccess" Color="#4A9E6A" />

                <!-- UI-specific -->
                <SolidColorBrush x:Key="DirtyDot" Color="#C88B2A" />
                <SolidColorBrush x:Key="TabName" Color="#8A8A98" />
                <SolidColorBrush x:Key="TabClose" Color="#5A5A6A" />
                <SolidColorBrush x:Key="EvictedText" Color="#5A5A6A" />
                <SolidColorBrush x:Key="PinIcon" Color="#8A8A98" />

            </Styles.Resources>

            <!-- ══ SCROLLING ══ -->

            <Style Selector="ScrollViewer">
                <Setter Property="AllowAutoHide" Value="False" />
            </Style>
            <Style Selector="ScrollBar">
                <Setter Property="Width" Value="14" />
                <Setter Property="MinWidth" Value="14" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Opacity" Value="0.6" />
            </Style>

            <!-- ══ LIST CONTROLS ══ -->

            <Style Selector="ListBox">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="Padding" Value="0" />
            </Style>
            <Style Selector="ListBoxItem">
                <Setter Property="Padding" Value="10 6" />
                <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                <Setter Property="FontSize" Value="12.5" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="Margin" Value="4 1" />
            </Style>
            <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
              
            </Style>
            <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
               
                <Setter Property="TextBlock.Foreground" Value="{StaticResource TextPrimary}" />
            </Style>

            <!-- ══ TEXT INPUT ══ -->

            <Style Selector="TextBox">
                <Setter Property="Background" Value="{StaticResource BgInput}" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                <Setter Property="CaretBrush" Value="{StaticResource Accent}" />
                <Setter Property="SelectionBrush" Value="{StaticResource AccentMuted}" />
                <Setter Property="Padding" Value="8 5" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="FontSize" Value="12.5" />
                <Setter Property="MinHeight" Value="28" />
            </Style>

            <Style Selector="CheckBox">
                <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                <Setter Property="FontSize" Value="12.5" />
            </Style>

            <!-- ══ BUTTONS ══ -->

            <Style Selector="Button">
                <Setter Property="Background" Value="{StaticResource BgElevated}" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                <Setter Property="Padding" Value="12 5" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Cursor" Value="Hand" />
            </Style>
            <Style Selector="Button:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="{StaticResource BgHover}" />
                <Setter Property="TextBlock.Foreground" Value="{StaticResource TextPrimary}" />
            </Style>
            <Style Selector="Button:pressed /template/ ContentPresenter">
                <Setter Property="Background" Value="{StaticResource AccentMuted}" />
            </Style>

            <!-- Filter pill (toggle button look) -->
            <Style Selector="Button.FilterPill">
                <Setter Property="Background" Value="{StaticResource BgInput}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="10 4" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Margin" Value="2 0" />
            </Style>
            <Style Selector="Button.FilterPill.active">
                <Setter Property="Background" Value="{StaticResource AccentMuted}" />
                <Setter Property="Foreground" Value="{StaticResource AccentHover}" />
            </Style>
            <Style Selector="Button.FilterPill.include">
                <Setter Property="Background" Value="{StaticResource AccentMuted}" />
                <Setter Property="Foreground" Value="{StaticResource AccentHover}" />
            </Style>
            <Style Selector="Button.FilterPill.exclude">
                <Setter Property="Background" Value="#3A2020" />
                <Setter Property="Foreground" Value="{StaticResource StatusError}" />
            </Style>

            <!-- Inline navigation link (e.g. proc list → distribution) -->
            <Style Selector="Button.NavLink">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
            <Style Selector="Button.NavLink:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="TextBlock.TextDecorations" Value="Underline" />
            </Style>

            <!-- Transparent "+" add-row link -->
            <Style Selector="Button.AddLink">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Foreground" Value="{StaticResource Accent}" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Padding" Value="6 3" />
                <Setter Property="Margin" Value="4 4" />
                <Setter Property="HorizontalAlignment" Value="Left" />
            </Style>

            <!-- Panel close button (×) -->
            <Style Selector="Button.PanelClose">
                <Setter Property="Content" Value="×" />
                <Setter Property="Width" Value="18" />
                <Setter Property="Height" Value="18" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                <Setter Property="HorizontalAlignment" Value="Right" />
                <Setter Property="VerticalAlignment" Value="Top" />
                <Setter Property="Margin" Value="0 4 4 0" />
                <Setter Property="ZIndex" Value="10" />
                <Setter Property="ToolTip.Tip" Value="{x:Static loc:Strings.PanelCloseTip}" />
            </Style>

            <!-- ══ TABS ══ -->

            <Style Selector="TabControl">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0" />
               
            </Style>
            <Style Selector="TabItem">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Padding" Value="14 0" />
                <Setter Property="Margin" Value="0" />
                <Setter Property="MinHeight" Value="0" />
            </Style>
            <Style Selector="TabItem:selected">
                <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            </Style>

            <!-- Tab strip scroll buttons (◀ / ▶) -->
            <Style Selector="Button.TabScroll">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                <Setter Property="Width" Value="24" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="VerticalAlignment" Value="Stretch" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="CornerRadius" Value="0" />
            </Style>
            <Style Selector="Button.TabScroll:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="{StaticResource BgHover}" />
                <Setter Property="TextBlock.Foreground" Value="{StaticResource TextSecondary}" />
            </Style>

            <!-- ══ DATA GRID ══ -->

            <Style Selector="DataGrid">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="RowBackground" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="GridLinesVisibility" Value="Horizontal" />
                <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderSubtle}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                <Setter Property="ColumnHeaderHeight" Value="32" />
                <Setter Property="RowHeight" Value="28" />
            </Style>
            <Style Selector="DataGridColumnHeader">
                <Setter Property="Background" Value="{StaticResource BgElevated}" />
                <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Padding" Value="12 0" />
                <Setter Property="BorderThickness" Value="0 0 0 1" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderMid}" />
                <Setter Property="SeparatorBrush" Value="{StaticResource BorderSubtle}" />
            </Style>
            <Style Selector="DataGridCell">
                <Setter Property="Padding" Value="12 0" />
                <Setter Property="BorderThickness" Value="0" />
            </Style>

            <!-- ══ TREE VIEW ══ -->

            <Style Selector="TreeView">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="Padding" Value="0" />
            </Style>
            <Style Selector="TreeViewItem">
                <Setter Property="IsExpanded" Value="{ReflectionBinding IsExpanded, Mode=TwoWay}" />
                <Setter Property="Padding" Value="6 4" />
                <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                <Setter Property="FontSize" Value="12.5" />
                <Setter Property="Margin" Value="0" />
            </Style>
            <Style Selector="TreeViewItem:selected /template/ ContentPresenter#PART_HeaderPresenter">
                <Setter Property="TextBlock.Foreground" Value="{StaticResource TextPrimary}" />
            </Style>
            <Style Selector="TreeViewItem:pointerover /template/ ContentPresenter#PART_HeaderPresenter">
               
            </Style>
            <Style Selector="TreeViewItem.droptarget /template/ ContentPresenter#PART_HeaderPresenter">
                <Setter Property="TextBlock.Foreground" Value="{StaticResource TextPrimary}" />
            </Style>

            <!-- ══ EXPANDER ══ -->

            <Style Selector="Expander /template/ ToggleButton">
                <Setter Property="Padding" Value="10 8" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            </Style>
            <Style Selector="Expander /template/ ContentPresenter">
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            </Style>

            <!-- ══ LAYOUT ══ -->

            <Style Selector="GridSplitter">
                <Setter Property="Background" Value="{StaticResource BorderSubtle}" />
            </Style>

            <Style Selector="Separator">
                <Setter Property="Background" Value="{StaticResource BorderSubtle}" />
                <Setter Property="Height" Value="1" />
                <Setter Property="Margin" Value="0 4" />
            </Style>

            <!-- ══ TYPOGRAPHY ══ -->

            <!-- Form field labels (e.g. "Rolls", "Min / Max") -->
            <Style Selector="TextBlock.FieldLabel">
                <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <!-- Compact inline labels (e.g. header settings row) -->
            <Style Selector="TextBlock.HeaderLabel">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <!-- Section headings inside panels (e.g. SETTINGS, ITEMS, JUNK) -->
            <Style Selector="TextBlock.SectionHeader">
                <Setter Property="FontSize" Value="9" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="LetterSpacing" Value="1" />
                <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            </Style>

            <!-- Top-level panel titles (e.g. DISTRIBUTIONS, ERROR LIST) -->
            <Style Selector="TextBlock.PanelHeader">
                <Setter Property="FontSize" Value="10" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="LetterSpacing" Value="1.5" />
                <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

        </Styles>
        
    </Application.Styles>
</Application>
