<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:UI.Assets"
        x:Class="UI.HelpWindow"
        x:CompileBindings="False"
        Title="{x:Static loc:Strings.HelpTitle}"
        Width="780" Height="560" MinWidth="540" MinHeight="400"
        Background="{StaticResource BgBase}"
        FontFamily="Inter,Segoe UI,system-ui,sans-serif"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="Full"
        CanResize="True">

    <Grid ColumnDefinitions="200,1,*">

        <!-- ── Sidebar ── -->
        <Border Grid.Column="0"
                Background="{StaticResource BgPanel}"
                Padding="0 8">
            <Grid RowDefinitions="Auto,*">
                <StackPanel Grid.Row="0" Margin="16 8 16 12">
                    <TextBlock Text="{x:Static loc:Strings.HelpHeader}"
                               FontSize="10" FontWeight="SemiBold" LetterSpacing="1.5"
                               Foreground="{StaticResource TextMuted}" />
                </StackPanel>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ListBox x:Name="TopicList" SelectionChanged="TopicList_SelectionChanged">
                        <ListBoxItem Tag="welcome"        Content="{x:Static loc:Strings.HelpWelcome}" />
                        <ListBoxItem Tag="getting-started" Content="{x:Static loc:Strings.HelpGettingStarted}" />
                        <ListBoxItem Tag="dist-list"      Content="{x:Static loc:Strings.HelpDistExplorer}" />
                        <ListBoxItem Tag="filters"        Content="{x:Static loc:Strings.HelpFilters}" />
                        <ListBoxItem Tag="detail-view"    Content="{x:Static loc:Strings.HelpDetailView}" />
                        <ListBoxItem Tag="containers"     Content="{x:Static loc:Strings.HelpContainers}" />
                        <ListBoxItem Tag="editing"        Content="{x:Static loc:Strings.HelpEditing}" />
                        <ListBoxItem Tag="saving"         Content="{x:Static loc:Strings.HelpSaving}" />
                        <ListBoxItem Tag="error-list"     Content="{x:Static loc:Strings.HelpErrorList}" />
                        <ListBoxItem Tag="shortcuts"      Content="{x:Static loc:Strings.HelpShortcuts}" />
                        <ListBoxItem Tag="items-list"     Content="{x:Static loc:Strings.HelpItemsExplorer}" />
                        <ListBoxItem Tag="items-detail"   Content="{x:Static loc:Strings.HelpItemsDetail}" />
                    </ListBox>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ── Divider ── -->
        <Border Grid.Column="1" Background="{StaticResource BorderSubtle}" />

        <!-- ── Content ── -->
        <Border Grid.Column="2" Background="{StaticResource BgBase}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24 16 24 24">
                <StackPanel x:Name="ContentPanel" Spacing="0" MaxWidth="520" />
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
