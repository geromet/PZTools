<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:UI.Controls"
        xmlns:loc="clr-namespace:UI.Assets"
        x:Class="UI.MainWindow"
        x:CompileBindings="False"
        Title="{x:Static loc:Strings.AppTitle}"
        Width="1280" Height="800" MinWidth="900" MinHeight="500"
        Background="{StaticResource BgBase}"
        FontFamily="Inter,Segoe UI,system-ui,sans-serif">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ══ TOOLBAR ══ -->
        <Border Grid.Row="0"
                                               Background="{StaticResource BgPanel}"
                                               BorderBrush="{StaticResource BorderSubtle}"
                                               BorderThickness="0 0 0 1"
                                               Padding="12 6">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="{x:Static loc:Strings.AppLabel}"
                           Foreground="{StaticResource TextPrimary}"
                           FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0 0 16 0"/>

                <!-- File actions -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="4">
                    <Button Content="{x:Static loc:Strings.BtnOpenFolder}" Click="SelectFolder_Click"/>
                    <Button x:Name="SaveBtn"
                            Content="{x:Static loc:Strings.BtnSave}"
                            Click="Save_Click"
                            IsEnabled="False"
                            ToolTip.Tip="{x:Static loc:Strings.BtnSaveTip}"/>
                    <Button Content="{x:Static loc:Strings.BtnReload}"
                            Click="Reload_Click"
                            ToolTip.Tip="{x:Static loc:Strings.BtnReloadTip}"/>
                </StackPanel>

                <!-- Undo / Redo -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal"
                            Spacing="4" Margin="12 0 0 0">
                    <Button x:Name="UndoBtn"
                            IsEnabled="False"
                            Click="UndoBtn_Click"
                            ToolTip.Tip="{x:Static loc:Strings.UndoNothingToUndo}">
                        <TextBlock Text="↩  Undo" Foreground="{StaticResource TextSecondary}"/>
                    </Button>
                    <Button x:Name="RedoBtn"
                            IsEnabled="False"
                            Click="RedoBtn_Click"
                            ToolTip.Tip="{x:Static loc:Strings.UndoNothingToRedo}">
                        <TextBlock Text="↪  Redo" Foreground="{StaticResource TextSecondary}"/>
                    </Button>
                </StackPanel>

                <!-- View menu -->
                <Menu DockPanel.Dock="Left" VerticalAlignment="Center" Margin="12 0 0 0">
                    <MenuItem Header="{x:Static loc:Strings.MenuView}">
                        <MenuItem x:Name="ViewListItem"   Header="{x:Static loc:Strings.MenuViewDistList}" Tag="List"   Click="ViewMenuItem_Click" />
                        <MenuItem x:Name="ViewItemsItem"  Header="{x:Static loc:Strings.MenuViewItemList}" Tag="Items"  Click="ViewMenuItem_Click" />
                        <MenuItem x:Name="ViewDetailItem" Header="{x:Static loc:Strings.MenuViewDetail}"   Tag="Detail" Click="ViewMenuItem_Click" />
                        <MenuItem x:Name="ViewErrorItem"  Header="{x:Static loc:Strings.MenuViewError}"    Tag="Error"  Click="ViewMenuItem_Click" />
                        <MenuItem x:Name="ViewRightItem"  Header="{x:Static loc:Strings.MenuViewRight}"    Tag="Right"  Click="ViewMenuItem_Click" />
                    </MenuItem>
                </Menu>

                <!-- Help -->
                <Button DockPanel.Dock="Right" Content="{x:Static loc:Strings.BtnHelp}" Click="HelpBtn_Click"
                        Margin="8 0 0 0" VerticalAlignment="Center"
                        ToolTip.Tip="{x:Static loc:Strings.BtnHelpTip}" />

                <!-- Loading indicator -->
                <ProgressBar x:Name="LoadingBar"
                             DockPanel.Dock="Right"
                             IsIndeterminate="True"
                             IsVisible="False"
                             Width="80" Height="4"
                             Foreground="{StaticResource Accent}"
                             Background="Transparent"
                             Margin="8 0" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
        <!-- ══ THREE-PANE BODY ══ -->
        <Grid x:Name="MainGrid"
              Grid.Row="1"
              ColumnDefinitions="260,4,260,4,*,4,260"
              RowDefinitions="*,4,160">

            <!-- LEFT — Distribution list -->
            <Grid x:Name="LeftPanelGrid" Grid.Column="0" Grid.RowSpan="3">
                <Border Background="{StaticResource BgPanel}"
                        BorderBrush="{StaticResource BorderSubtle}"
                        BorderThickness="0 0 1 0">
                    <controls:DistributionListControl x:Name="DistributionList" />
                </Border>
                <Button Classes="PanelClose" Tag="List"   Click="ClosePanelBtn_Click" />
            </Grid>

            <GridSplitter x:Name="LeftSplitter"
                          Grid.Column="1" Grid.RowSpan="3"
                          ResizeDirection="Columns"
                          HorizontalAlignment="Stretch"/>

            <!-- ITEMS — Item explorer -->
            <Grid x:Name="ItemsListGrid" Grid.Column="2" Grid.RowSpan="3">
                <Border Background="{StaticResource BgPanel}"
                        BorderBrush="{StaticResource BorderSubtle}"
                        BorderThickness="0 0 1 0">
                    <controls:ItemsListControl x:Name="ItemsList" />
                </Border>
                <Button Classes="PanelClose" Tag="Items" Click="ClosePanelBtn_Click" />
            </Grid>

            <GridSplitter x:Name="ItemsSplitter"
                          Grid.Column="3" Grid.RowSpan="3"
                          ResizeDirection="Columns"
                          HorizontalAlignment="Stretch"/>

            <!-- CENTER — Tabbed detail panel -->
            <Grid x:Name="DetailPanelGrid" Grid.Column="4" Grid.Row="0">
                <Border Background="{StaticResource BgBase}">
                    <TabControl x:Name="TabBar"
                                SelectionChanged="TabBar_SelectionChanged"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch">
                        <TabControl.Theme>
                            <ControlTheme TargetType="TabControl">
                                <Setter Property="ItemsPanel">
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </Setter>
                                <Setter Property="Template">
                                    <ControlTemplate>
                                        <Grid RowDefinitions="40,*">
                                            <!-- Tab strip: 40px tall, clipped, with scroll buttons -->
                                            <Border Grid.Row="0"
                                                    Background="{StaticResource BgPanel}"
                                                    BorderBrush="{StaticResource BorderSubtle}"
                                                    BorderThickness="0 0 0 1"
                                                    ClipToBounds="True">
                                                <Grid ColumnDefinitions="24,*,24"
                                                      Margin="0">
                                                    <Button x:Name="PART_ScrollLeft"
                                                            Grid.Column="0"
                                                            Classes="TabScroll"
                                                            Content="&#x2039;" />
                                                    <ScrollViewer Name="PART_TabScrollViewer"
                                                                  Grid.Column="1"
                                                                  HorizontalScrollBarVisibility="Hidden"
                                                                  VerticalScrollBarVisibility="Disabled">
                                                        <ItemsPresenter Name="PART_ItemsPresenter"
                                                                        ItemsPanel="{TemplateBinding ItemsPanel}"
                                                                        HorizontalAlignment="Left" />
                                                    </ScrollViewer>
                                                    <Button x:Name="PART_ScrollRight"
                                                            Grid.Column="2"
                                                            Classes="TabScroll"
                                                            Content="&#x203A;" />
                                                </Grid>
                                            </Border>
                                            <!-- Content area -->
                                            <ContentPresenter Name="PART_SelectedContentHost"
                                                              Grid.Row="1"
                                                              Content="{TemplateBinding SelectedContent}"
                                                              ContentTemplate="{TemplateBinding SelectedContentTemplate}"
                                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                              Margin="{TemplateBinding Padding}" />
                                        </Grid>
                                    </ControlTemplate>
                                </Setter>
                            </ControlTheme>
                        </TabControl.Theme>
                    </TabControl>
                </Border>
                <Button Classes="PanelClose" Tag="Detail" Click="ClosePanelBtn_Click" />
            </Grid>

            <GridSplitter x:Name="ErrorSplitter"
                          Grid.Column="4" Grid.Row="1"
                          ResizeDirection="Rows"
                          HorizontalAlignment="Stretch"/>

            <!-- BOTTOM — Error list -->
            <Grid x:Name="ErrorPanelGrid" Grid.Column="4" Grid.Row="2">
                <Border Background="{StaticResource BgPanel}"
                        BorderBrush="{StaticResource BorderSubtle}"
                        BorderThickness="0 1 0 0">
                    <controls:ErrorListControl x:Name="ErrorList" />
                </Border>
                <Button Classes="PanelClose" Tag="Error"  Click="ClosePanelBtn_Click" />
            </Grid>

            <GridSplitter x:Name="RightSplitter"
                          Grid.Column="5" Grid.RowSpan="3"
                          ResizeDirection="Columns"
                          HorizontalAlignment="Stretch"/>

            <!-- RIGHT — Properties panel -->
            <Grid x:Name="RightPanelGrid" Grid.Column="6" Grid.RowSpan="3">
                <Border Background="{StaticResource BgPanel}"
                        BorderBrush="{StaticResource BorderSubtle}"
                        BorderThickness="1 0 0 0">
                    <Grid RowDefinitions="Auto,*">
                        <Border Grid.Row="0" Padding="14 7 12 7"
                                BorderBrush="{StaticResource BorderSubtle}"
                                BorderThickness="0 0 0 1">
                            <TextBlock Text="{x:Static loc:Strings.PanelProperties}" Classes="PanelHeader" />
                        </Border>
                        <controls:DistributionDetailControl x:Name="RightDetail" Grid.Row="1" />
                    </Grid>
                </Border>
                <Button Classes="PanelClose" Tag="Right"  Click="ClosePanelBtn_Click" />
            </Grid>
        </Grid>
        <!-- ══ STATUS BAR ══ -->
        <Border Grid.Row="2"
                Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0 1 0 0"
                Padding="12 4">
            <DockPanel>
                <TextBlock x:Name="CountText"
                           DockPanel.Dock="Right"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="11" VerticalAlignment="Center"
                           Margin="0 0 8 0"/>
                <TextBlock x:Name="StatusText"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="11" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>

</Window>
