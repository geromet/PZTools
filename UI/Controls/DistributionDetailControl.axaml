<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:UI.Controls"
             xmlns:ir="using:Avalonia.Controls"
             xmlns:irlayout="using:Avalonia.Layout"
             xmlns:loc="clr-namespace:UI.Assets"
             x:Class="UI.Controls.DistributionDetailControl"
             x:CompileBindings="False">

    <Grid>
        <!-- Empty state -->
        <StackPanel x:Name="EmptyPanel"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Spacing="8"
                    Margin="0 4 4 0">
            <TextBlock Text="{x:Static loc:Strings.DDEmptyTitle}"
                       FontSize="14"
                       Foreground="{StaticResource TextMuted}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="{x:Static loc:Strings.DDEmptySubtitle}"
                       FontSize="12"
                       Foreground="{StaticResource TextMuted}"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Detail view -->
        <Grid x:Name="DetailPanel" IsVisible="False" RowDefinitions="Auto,Auto,Auto,*">

            <!-- Distribution header -->
            <Border Grid.Row="0"
                    Padding="4"
                    BorderBrush="{StaticResource BorderSubtle}"
                    BorderThickness="0"
                    Background="{StaticResource BgPanel}"
                    Margin="0 ">
                <StackPanel Spacing="4">
                    <!-- Name + type badge -->
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock x:Name="HeaderName"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}" />
                        <Border CornerRadius="4" Padding="4 4"
                                Background="{StaticResource BgElevated}">
                            <TextBlock x:Name="HeaderType"
                                       FontSize="11"
                                       Foreground="{StaticResource TextMuted}" />
                        </Border>
                    </StackPanel>

                    <!-- Editable settings row -->
                    <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*"
                          RowDefinitions="Auto"
                          Margin="0 4 0 0" ColumnSpacing="10">

                        <TextBlock Grid.Column="0" Text="{x:Static loc:Strings.DDRolls}" Classes="HeaderLabel" />
                        <TextBox x:Name="RollsBox" Grid.Column="1"
                                 Width="50" FontSize="11" Padding="4 2"
                                 LostFocus="RollsBox_LostFocus" />

                        <CheckBox x:Name="ShopCheck" Grid.Column="2"
                                  Content="{x:Static loc:Strings.DDShop}" FontSize="11"
                                  IsCheckedChanged="ShopCheck_IsCheckedChanged" />

                        <CheckBox x:Name="NoAmmoCheck" Grid.Column="3"
                                  Content="{x:Static loc:Strings.DDNoAmmo}" FontSize="11"
                                  IsCheckedChanged="NoAmmoCheck_IsCheckedChanged" />

                        <TextBlock x:Name="MaxMapLabel" Grid.Column="4" Text="{x:Static loc:Strings.DDMaxMap}" Classes="HeaderLabel" />
                        <TextBox x:Name="MaxMapBox" Grid.Column="5"
                                 Width="50" FontSize="11" Padding="4 2"
                                 LostFocus="MaxMapBox_LostFocus" />

                        <TextBlock x:Name="StashLabel" Grid.Column="6" Text="{x:Static loc:Strings.DDStash}" Classes="HeaderLabel" />
                        <TextBox x:Name="StashBox" Grid.Column="7"
                                 Width="50" FontSize="11" Padding="4 2"
                                 LostFocus="StashBox_LostFocus" />

                        <TextBlock Grid.Column="8" FontSize="11" Foreground="{StaticResource TextMuted}">
                            <Run Text="Containers: " />
                            <Run x:Name="HeaderContainerCount" Foreground="{StaticResource TextSecondary}" />
                        </TextBlock>
                        <TextBlock x:Name="HeaderDirectItems" Grid.Column="9"
                                   FontSize="11" Foreground="{StaticResource TextMuted}"
                                   IsVisible="False">
                            <Run Text="Items: " />
                            <Run x:Name="HeaderDirectItemCount" Foreground="{StaticResource TextSecondary}" />
                        </TextBlock>
                    </Grid>

                    <!-- Back-links: distributions that reference this proc list -->
                    <Border x:Name="BackLinksPanel" IsVisible="False"
                            BorderBrush="{StaticResource BorderSubtle}"
                            BorderThickness="0 1 0 0"
                            Padding="0 4 0 4">
                        <StackPanel Spacing="2">
                            <TextBlock Text="{x:Static loc:Strings.DDReferencedBy}"
                                       FontSize="11" FontWeight="Medium"
                                       Foreground="{StaticResource TextMuted}" />
                            <WrapPanel x:Name="BackLinksRows" Orientation="Horizontal" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Toolbar: expand/collapse + container filters -->
            <Border x:Name="ToolbarPanel" Grid.Row="1"
                    Padding="8 4"
                    BorderBrush="{StaticResource BorderSubtle}"
                    BorderThickness="0 0 0 1">
                <WrapPanel Orientation="Horizontal">
                    <Button Classes="FilterPill" Content="{x:Static loc:Strings.DDExpandAll}" Click="ExpandAll_Click" Margin="2" />
                    <Button Classes="FilterPill" Content="{x:Static loc:Strings.DDCollapseAll}" Click="CollapseAll_Click" Margin="2" />
                    <Button x:Name="ShowEmptyBtn" Classes="FilterPill" Content="{x:Static loc:Strings.DDShowEmpty}" Click="ShowEmpty_Click" Margin="2"
                            ToolTip.Tip="{x:Static loc:Strings.DDShowEmptyTip}" />
                    <Border Width="1" Background="{StaticResource BorderSubtle}" Margin="6 2" />
                    <Button x:Name="AutoFilterBtn" Classes="FilterPill" Content="{x:Static loc:Strings.DDAutoFilter}" Click="AutoFilter_Click" Margin="2"
                            ToolTip.Tip="{x:Static loc:Strings.DDAutoFilterTip}" />
                    <Button Classes="FilterPill" Content="{x:Static loc:Strings.DDClear}" Click="ClearFilters_Click" Margin="2"
                            ToolTip.Tip="{x:Static loc:Strings.DDClearTip}" />
                    <Border Width="1" Background="{StaticResource BorderSubtle}" Margin="6 2" />
                    <WrapPanel x:Name="ContainerFilterPills" Orientation="Horizontal">
                        <Button Classes="FilterPill" Content="{x:Static loc:Strings.DDFilterProcList}" Tag="ProcList" Margin="2" />
                        <Button Classes="FilterPill" Content="{x:Static loc:Strings.DDFilterRolls}" Tag="Rolls" Margin="2" />
                        <Button Classes="FilterPill" Content="{x:Static loc:Strings.DDFilterItems}" Tag="Items" Margin="2" />
                        <Button Classes="FilterPill" Content="{x:Static loc:Strings.DDFilterJunk}" Tag="Junk" Margin="2" />
                        <Button Classes="FilterPill" Content="{x:Static loc:Strings.DDFilterProcedural}" Tag="Procedural" Margin="2" />
                        <Button Classes="FilterPill" Content="{x:Static loc:Strings.DDFilterInvalid}" Tag="Invalid" Margin="2" />
                    </WrapPanel>
                </WrapPanel>
            </Border>

            <!-- Row 2: Distribution-level items (pinned above scroll) -->
            <Border x:Name="DirectItemsPanel" Grid.Row="2"
                    IsVisible="False"
                    Margin="8 2"
                    CornerRadius="6"
                    Background="{StaticResource BgSurface}"
                    BorderBrush="{StaticResource BorderSubtle}"
                    BorderThickness="1"
                    ClipToBounds="True">
                <Expander IsExpanded="True" Padding="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                    <Expander.Header>
                        <Grid ColumnDefinitions="*,Auto,Auto" Margin="4 0">
                            <TextBlock Grid.Column="0"
                                       Text="{x:Static loc:Strings.DDDistItemsLabel}"
                                       FontSize="12.5" FontWeight="Medium"
                                       Foreground="{StaticResource TextMuted}"
                                       FontStyle="Italic"
                                       VerticalAlignment="Center" />
                            <Border Grid.Column="1" CornerRadius="3" Padding="6 2" Margin="6 0 0 0"
                                    Background="{StaticResource BgInput}"
                                    ToolTip.Tip="{x:Static loc:Strings.TipItemRolls}">
                                <TextBlock x:Name="DirectRollsBadge"
                                           FontSize="11" Foreground="{StaticResource TextMuted}" />
                            </Border>
                            <Border Grid.Column="2" CornerRadius="3" Padding="6 2" Margin="4 0 0 0"
                                    Background="{StaticResource BgInput}"
                                    ToolTip.Tip="{x:Static loc:Strings.TipUniqueItems}">
                                <TextBlock x:Name="DirectCountBadge"
                                           FontSize="11" Foreground="{StaticResource TextMuted}" />
                            </Border>
                        </Grid>
                    </Expander.Header>
                    <TabControl Margin="0">
                        <TabItem Header="{x:Static loc:Strings.DDTabItems}">
                            <controls:ItemListControl x:Name="DistItemsControl" />
                        </TabItem>
                        <TabItem x:Name="JunkTab" Header="{x:Static loc:Strings.DDTabJunk}">
                            <controls:ItemListControl x:Name="DistJunkControl" />
                        </TabItem>
                    </TabControl>
                </Expander>
            </Border>

            <!-- Row 3: Virtualized containers -->
            <ScrollViewer Grid.Row="3"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="0 4 0 0">
                <ir:ItemsRepeater x:Name="ContainersRepeater" Margin="0 0 0 16">
                    <ir:ItemsRepeater.Layout>
                        <irlayout:StackLayout Spacing="0" />
                    </ir:ItemsRepeater.Layout>
                    <ir:ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <controls:ContainerControl />
                        </DataTemplate>
                    </ir:ItemsRepeater.ItemTemplate>
                </ir:ItemsRepeater>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
